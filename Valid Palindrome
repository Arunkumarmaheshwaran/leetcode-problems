class Solution {
    public boolean isPalindrome(String s) {
        s = s.toLowerCase();
		StringBuffer sb = new StringBuffer();
		for(int i=0;i<s.length();i++) {
			char ch = s.charAt(i);
			if (Character.isLetterOrDigit(ch)) {
                sb.append(ch);
            }
		}
		if(sb.toString().equals(sb.reverse().toString()))
			return true;
		return false;
		
    }
}
